n=input("Enter a number")-Counting the frequency of letter
c={}
for i in n:
    if i in c:
        c[i]+=1
    else:
        c[i]=1
print (c)

n=input("Enter a number")-Counting the frequency of words
c={}
for i in n.split():
    if i in c:
        c[i]+=1
    else:
        c[i]=1
print (c)


